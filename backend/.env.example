MONGO_URI=mongodb://127.0.0.1:27017/e-commerce
PORT=5001
JWT_SECRET=change-me-in-production

# Cloudinary (optional — image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Bakong KHQR (optional)
BAKONG_TOKEN=
BAKONG_ACCOUNT_ID=
BAKONG_API_URL=https://api-bakong.nbc.gov.kh/v1

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google OAuth (optional — Google Cloud Console → OAuth 2.0 Client ID, Web application)
GOOGLE_CLIENT_ID=

# Telegram Login (optional — create bot via @BotFather, set domain with /setdomain)
TELEGRAM_BOT_TOKEN=

# Telegram OpenID Connect (BotFather → Login Widget → Switch to OpenID Connect)
TELEGRAM_OIDC_CLIENT_ID=
TELEGRAM_OIDC_CLIENT_SECRET=

# Storefront URL for Stripe/KHQR redirect links (production: https://your-store.vercel.app)
CLIENT_URL=http://localhost:3000

# Public backend URL for PayWay webhook (production: https://your-vps/ecomerce/api)
BACKEND_PUBLIC_URL=http://127.0.0.1:5001/api

# ABA PayWay (optional — sandbox or production)
# PAYWAY_PUBLIC_KEY is used for HMAC hash signing (renew before expiry — error code 21)
PAYWAY_MERCHANT_ID=
PAYWAY_PUBLIC_KEY=
PAYWAY_API_URL=https://checkout-sandbox.payway.com.kh/api/payment-gateway/v1/payments/purchase
PAYWAY_QR_LIFETIME=30
PAYWAY_QR_TEMPLATE=template3_color
# Optional RSA pair (only needed for some PayWay encryption flows)
PAYWAY_RSA_PUBLIC_KEY=
PAYWAY_RSA_PRIVATE_KEY=
